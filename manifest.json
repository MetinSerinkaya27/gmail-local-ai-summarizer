{
  "manifest_version": 3,
  "name": "Yerel AI Gizli Özetleyici",
  "version": "1.0",
  "description": "Gizli şirket maillerini %100 yerel yapay zeka ile doğrudan tarayıcında özetler.",
  "permissions": [
    "activeTab",
    "offscreen"
  ],
  "content_scripts": [
    {
      "matches": ["*://mail.google.com/*"],
      "js": ["content.js"]
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self';"
  }
}